<Window x:Class="USBGuardianControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="USB Guardian Endpoint Security" Height="680" Width="1080"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        FontFamily="Segoe UI" Background="#F0F2F5">
    <Window.Resources>
        <!-- Buttons -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#0078D7"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#005A9E"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="DangerBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#D13438"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#A80000"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="SuccessBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#107C10"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0B5A0B"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="GhostBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E1DFDD"/><Setter Property="Foreground" Value="#323130"/></Trigger></Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡 USB Guardian" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text=" — Network Control Panel" FontSize="14" Foreground="#8899AA" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                </StackPanel>

                <!-- Server connection -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0" VerticalAlignment="Center">
                    <TextBox x:Name="txtServerUrl" Text="http://localhost:5050" Width="200" Height="28"
                             Padding="6,4" Background="#2D2D44" Foreground="White" BorderBrush="#444466"
                             BorderThickness="1" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                    <PasswordBox x:Name="txtPassword" Width="120" Height="28" Padding="6,4"
                                 Background="#2D2D44" Foreground="White" BorderBrush="#444466" BorderThickness="1"
                                 VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="Connect" Style="{StaticResource PrimaryBtn}" Click="BtnConnect_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔴 Lock All" Style="{StaticResource DangerBtn}" Margin="0,0,8,0" Click="BtnLockAll_Click"/>
                    <Button Content="🟢 Unlock All" Style="{StaticResource SuccessBtn}" Click="BtnUnlockAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>   <!-- Left: agent list -->
                <ColumnDefinition Width="*"/>     <!-- Right: machine detail -->
            </Grid.ColumnDefinitions>

            <!-- LEFT: Agent list -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,12,0"
                    BorderBrush="#E1DFDD" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F4F6F9" CornerRadius="8,8,0,0" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Connected Machines" FontWeight="SemiBold" FontSize="13"/>
                            <Border Background="#0078D7" CornerRadius="10" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="lblAgentCount" Text="0" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1" x:Name="lbAgents" Background="Transparent" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="LbAgents_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" BorderBrush="#E1DFDD" BorderThickness="0,0,0,1"
                                                    Background="{TemplateBinding Background}" Padding="12,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#EBF3FB"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D7"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F4F6F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding OnlineIcon}" Foreground="{Binding OnlineColor}" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding MachineName}" FontWeight="SemiBold" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding IpAddress}" FontSize="10" Foreground="#A19F9D"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{Binding StatusBg}" CornerRadius="4"
                                            Padding="5,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- RIGHT: Selected machine detail -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Machine header + controls -->
                    <RowDefinition Height="Auto"/>   <!-- Section label -->
                    <RowDefinition Height="*"/>      <!-- Device list -->
                    <RowDefinition Height="Auto"/>   <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- Machine controls -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderBrush="#E1DFDD" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="lblSelectedMachine" Text="← Select a machine from the list"
                                       FontSize="16" FontWeight="Bold" Foreground="#323130"/>
                            <TextBlock x:Name="lblMachineStatus" Text="" FontSize="12" Foreground="#605E5C" Margin="0,2,0,0"/>
                        </StackPanel>
                        <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Unlock Indefinitely" Style="{StaticResource SuccessBtn}" Margin="0,0,8,5" Click="BtnUnlock_Click"/>
                            <Button Content="Lock System"         Style="{StaticResource DangerBtn}"  Margin="0,0,8,5" Click="BtnLock_Click"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,5">
                                <TextBox x:Name="txtMinutes" Width="40" Height="28" Text="30" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                <TextBlock Text=" mins" VerticalAlignment="Center"/>
                                <Button Content=" Unlock Timed" Style="{StaticResource PrimaryBtn}" Margin="8,0,0,0" Click="BtnTimedUnlock_Click"/>
                            </StackPanel>
                            <Button Content="⟳ Refresh" Style="{StaticResource GhostBtn}" Click="BtnRefresh_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- Section label -->
                <TextBlock Grid.Row="1" Text="USB Ports &amp; Connected Devices"
                           FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>

                <!-- Device list -->
                <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#E1DFDD" BorderThickness="1" Padding="1">
                    <ListView x:Name="lvDevices" BorderThickness="0" Background="Transparent"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderBrush" Value="#E1DFDD"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Hub row -->
                                    <Grid Visibility="{Binding HubRowVisibility}" Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⬡ " Foreground="#0078D7" FontSize="13"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DeviceID}" FontSize="10" Foreground="#A19F9D" Margin="18,1,0,1" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="18,0,0,0">
                                                <TextBlock Text="HW: " FontSize="11" Foreground="#605E5C"/>
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#0078D7" FontWeight="SemiBold"/>
                                                <TextBlock Text="  |  Policy: " FontSize="11" Foreground="#605E5C"/>
                                                <TextBlock Text="{Binding PolicyText}" FontSize="11" Foreground="{Binding PolicyColor}" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Allow" Style="{StaticResource SuccessBtn}" Width="60" Margin="5,0"
                                                    Visibility="{Binding ShowAllow}" Click="BtnAllowDevice_Click" Tag="{Binding DeviceID}"/>
                                            <Button Content="Block" Style="{StaticResource DangerBtn}"  Width="60" Margin="5,0"
                                                    Visibility="{Binding ShowBlock}" Click="BtnBlockDevice_Click" Tag="{Binding DeviceID}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Connected device row -->
                                    <Border Visibility="{Binding DeviceRowVisibility}"
                                            Background="#F9F8F7" Margin="30,0,0,0"
                                            BorderBrush="#E1DFDD" BorderThickness="2,0,0,0">
                                        <StackPanel Margin="12,7">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔌 " FontSize="12"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                                <Border Background="{Binding ConnectedColor}" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ConnectedLabel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DeviceID}" FontSize="9" Foreground="#A19F9D" Margin="20,1,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Status bar -->
                <Border Grid.Row="3" Background="#E1DFDD" CornerRadius="4" Padding="10" Margin="0,10,0,0">
                    <TextBlock x:Name="lblStatus" Text="Enter server URL and password, then click Connect."
                               TextWrapping="Wrap" HorizontalAlignment="Center"
                               FontWeight="SemiBold" Foreground="#323130"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
