<Window x:Class="USBGuardianControl.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Admin Password" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="#F4F6F9"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#C8C6C4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="CancelBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#8A8886"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#605E5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="24" Background="White" CornerRadius="8" Padding="24"
            BorderBrush="#E1DFDD" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Change Admin Password" FontSize="16" FontWeight="Bold"
                       Foreground="#323130" Margin="0,0,0,20"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="New Password:"
                           VerticalAlignment="Center" Foreground="#605E5C"/>
                <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="txtNewPwd"
                             Height="28" Padding="6,4" BorderBrush="#C8C6C4" BorderThickness="1"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Confirm:"
                           VerticalAlignment="Center" Foreground="#605E5C"/>
                <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="txtConfirmPwd"
                             Height="28" Padding="6,4" BorderBrush="#C8C6C4" BorderThickness="1"/>
            </Grid>

            <TextBlock x:Name="lblError" Text="" Foreground="#D13438"
                       FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Style="{StaticResource CancelBtn}"
                        Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button Content="Change Password" Style="{StaticResource PrimaryBtn}"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
